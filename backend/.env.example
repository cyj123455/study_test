# 复制为 .env 并填写
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=agri_price_db
SECRET_KEY=your-secret-key
DEBUG=false

# 初始化管理员（scripts/init_db.py 会自动创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456

