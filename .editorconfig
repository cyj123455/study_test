root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.py]
indent_size = 4
indent_style = space

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{sh,bat,cmd}]
end_of_line = crlf

[*.{yml,yaml,json}]
indent_size = 2

[*.{vue,ts,tsx,js,jsx}]
indent_size = 2

[*.html]
indent_size = 2
